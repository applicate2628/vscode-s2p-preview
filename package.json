{
  "name": "vscode-s2p-preview",
  "displayName": "Touchstone S-Parameter Preview",
  "description": "Preview S1P, S2P, S3P, and S4P Touchstone S-parameter files for RF simulation work.",
  "version": "0.0.10",
  "publisher": "applicate2628",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/applicate2628/vscode-s2p-preview.git"
  },
  "homepage": "https://github.com/applicate2628/vscode-s2p-preview#readme",
  "bugs": {
    "url": "https://github.com/applicate2628/vscode-s2p-preview/issues"
  },
  "keywords": [
    "touchstone",
    "s-parameter",
    "s-parameters",
    "s2p",
    "s1p",
    "s3p",
    "s4p",
    "snp",
    "rf",
    "microwave",
    "vna",
    "network-analyzer",
    "visualization"
  ],
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Data Science",
    "Other"
  ],
  "activationEvents": [
    "onCommand:s2pPreview.open",
    "onCommand:s2pPreview.openOverlay",
    "onCustomEditor:s2pPreview.editor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "S2P Preview",
      "properties": {
        "s2pPreview.passbandPresets": {
          "type": "array",
          "markdownDescription": "Named view presets shown in the S2P preview. Presets always store a passband range and may also store visible S-parameter traces plus per-port Z0 renormalization.",
          "default": [
            {
              "label": "1-10 GHz",
              "startGHz": 1,
              "stopGHz": 10
            }
          ],
          "items": {
            "type": "object",
            "required": [
              "label",
              "startGHz",
              "stopGHz"
            ],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string",
                "description": "Preset label shown in the preview."
              },
              "startGHz": {
                "type": "number",
                "description": "Passband start frequency in GHz."
              },
              "stopGHz": {
                "type": "number",
                "description": "Passband stop frequency in GHz."
              },
              "traces": {
                "type": "array",
                "description": "Optional visible S-parameter traces for this preset.",
                "items": {
                  "type": "object",
                  "required": [
                    "toPort",
                    "fromPort"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "toPort": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Destination/output port number in Sij."
                    },
                    "fromPort": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Source/input port number in Sij."
                    }
                  }
                }
              },
              "renormalize": {
                "type": "object",
                "description": "Optional per-port Z0 renormalization state for this preset.",
                "required": [
                  "selectedPorts",
                  "targetOhms"
                ],
                "additionalProperties": false,
                "properties": {
                  "selectedPorts": {
                    "type": "array",
                    "description": "Per-port flags indicating which ports should be renormalized.",
                    "items": {
                      "type": "boolean"
                    }
                  },
                  "targetOhms": {
                    "type": "array",
                    "description": "Per-port target real reference impedance values in Ohm.",
                    "items": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    }
                  }
                }
              }
            }
          }
        },
        "s2pPreview.defaultPassbandPreset": {
          "type": "string",
          "markdownDescription": "Label of the passband preset used when opening the preview. Use `Auto / Full file range` to span the loaded file.",
          "default": "Auto / Full file range"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "s2pPreview.editor",
        "displayName": "S2P Preview",
        "selector": [
          {
            "filenamePattern": "*.s1p"
          },
          {
            "filenamePattern": "*.s2p"
          },
          {
            "filenamePattern": "*.s3p"
          },
          {
            "filenamePattern": "*.s4p"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "s2pPreview.open",
        "title": "S2P: Preview Current File"
      },
      {
        "command": "s2pPreview.openOverlay",
        "title": "S2P: Preview Selected Files Overlay"
      }
    ],
    "menus": {
      "editor/title/context": [
        {
          "command": "s2pPreview.open",
          "when": "resourceExtname == .s1p || resourceExtname == .s2p || resourceExtname == .s3p || resourceExtname == .s4p",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "s2pPreview.open",
          "when": "resourceExtname == .s1p || resourceExtname == .s2p || resourceExtname == .s3p || resourceExtname == .s4p",
          "group": "navigation"
        },
        {
          "command": "s2pPreview.openOverlay",
          "when": "resourceExtname == .s1p || resourceExtname == .s2p || resourceExtname == .s3p || resourceExtname == .s4p",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test out/__tests__/*.test.js",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package --no-dependencies --readme-path README.marketplace.md",
    "release:patch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-patch.ps1",
    "release:patch:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-patch.ps1",
    "release:patch:bash": "bash scripts/release-patch.sh"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.4.5"
  }
}
